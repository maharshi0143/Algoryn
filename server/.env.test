PORT=5000
NODE_ENV=test

# ⚠️ Create a separate NeonDB for testing at https://neon.tech and put its URL here
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require

JWT_SECRET=test_access_token_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test_refresh_token_secret
JWT_REFRESH_EXPIRES_IN=7d

CLIENT_URL=http://localhost:5173

# Replace with your own test key
GROQ_API_KEY=your_groq_test_api_key

# Replace with your own test token
GITHUB_TOKEN=your_github_test_token

SENTRY_DSN=
SENTRY_ENV=test

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
