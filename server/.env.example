PORT=5000
NODE_ENV=development

# PostgreSQL (NeonDB)
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/db?sslmode=require

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Groq AI
GROQ_API_KEY=your_groq_api_key

# GitHub (for fetching contributions via GraphQL)
GITHUB_TOKEN=your_github_personal_access_token

# Sentry (optional — error tracking)
SENTRY_DSN=https://your-dsn@your-project.ingest.us.sentry.io/your-id
SENTRY_ENV=development

# SMTP (optional — for email reminders)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
